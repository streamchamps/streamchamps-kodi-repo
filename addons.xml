<?xml version="1.0" encoding="UTF-8"?>
<addons>
<addon id="repository.streamchamps" name="StreamChamps Repository" version="1.0.0" provider-name="StreamChamps">
  <requires>
    <import addon="xbmc.addon" version="12.0.0"/>
  </requires>
  <extension point="xbmc.addon.repository" name="StreamChamps Repository">
    <info compressed="false">https://streamchamps.github.io/streamchamps-kodi-repo/addons.xml</info>
    <checksum>https://streamchamps.github.io/streamchamps-kodi-repo/addons.xml.md5</checksum>
    <datadir zip="true">https://streamchamps.github.io/streamchamps-kodi-repo/</datadir>
  </extension>
  <extension point="xbmc.addon.metadata">
    <summary lang="en_US">Official StreamChamps Kodi repository.</summary>
    <description lang="en_US">Repository for StreamChamps Kodi add-ons.</description>
    <platform>all</platform>
    <assets>
      <icon>icon.png</icon>
    </assets>
  </extension>
</addon>
<addon id="plugin.video.streamchamps.news" name="StreamChamps News Hub" version="1.0.0" provider-name="StreamChamps">
  <requires>
    <import addon="xbmc.python" version="3.0.0"/>
  </requires>
  <extension point="xbmc.python.pluginsource" library="default.py">
    <provides>video</provides>
  </extension>
  <extension point="xbmc.addon.metadata">
    <summary lang="en_US">NFL and NBA news with StreamChamps branding.</summary>
    <description lang="en_US">StreamChamps News Hub pulls public ESPN NFL and NBA news headlines for Kodi 21 Omega. No live streams are provided.</description>
    <disclaimer lang="en_US">Unofficial fan add-on. This add-on only displays public news headlines and article summaries.</disclaimer>
    <platform>all</platform>
    <assets>
      <icon>resources/media/icon.png</icon>
      <fanart>resources/media/fanart.jpg</fanart>
      <screenshot>resources/media/fanart.jpg</screenshot>
    </assets>
  </extension>
</addon>
</addons>
